&CONTROL
    calculation       = 'vc-relax'
    restart_mode      = 'from_scratch'
    prefix            = 'silicene'
    tstress           = .true.
    tprnfor           = .true.
    pseudo_dir        = '../../Pseudo'
    outdir            = './tmp'
    verbosity         = 'high'
    wf_collect        = .true.
/
&SYSTEM
                       ibrav = 4,
                           A = 3.85,
                           C = 10,
                         nat = 2,
                        ntyp = 1,
                     ecutwfc = 20 ,
                        nbnd = 8,
                 occupations = 'smearing' ,
                     degauss = 0.01 ,
                    smearing = 'm-v' ,
/
&ELECTRONS
                 mixing_beta = 0.7 ,
/
&IONS
/
&CELL
   press_conv_thr=0.001
   cell_dofree="2Dxy"
!  cell_dofree="ibrav+2Dxy"   ! QE 7.0
/
ATOMIC_SPECIES
   Si   12.01100  Si.pz-vbc.UPF 
ATOMIC_POSITIONS crystal 
   Si      0.000000000    0.000000000    0.500000000     0 0 0
   Si      0.333333333    0.666666667    0.550000000     1 1 1
K_POINTS automatic
  9  9 1	0 0 0
