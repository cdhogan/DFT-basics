&CONTROL
  calculation  = "vc-relax",
  prefix       = "Si",
  pseudo_dir   = "../../Pseudo",
  outdir       = "./tmp",
  restart_mode = "from_scratch"
  verbosity    = "high"
  tprnfor = .true.
  wf_collect=.true.
/
&SYSTEM
  ibrav     = 2,
  A = 5.43,
  nat       = 2,
  ntyp      = 1,
  ecutwfc   = 20
  nbnd      = 5
/
&ELECTRONS
  conv_thr    = 1.D-8,
  mixing_beta = 0.7D0	,
/
&IONS
/
&CELL
!  press_conv_thr=0.001
   press_conv_thr=0.0
   cell_dofree="ibrav"
/
ATOMIC_SPECIES
 Si  28.086  Si.dojo-LDA.UPF 
ATOMIC_POSITIONS {alat}
 Si 0.00 0.00 0.00 0 0 0
 Si 0.25 0.25 0.25 0 0 0
K_POINTS {automatic}
4 4 4 1 1 1
