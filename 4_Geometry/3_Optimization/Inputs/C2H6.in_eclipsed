&CONTROL
    calculation = 'relax',
    prefix = 'C2H6',
    outdir = './tmp',
    pseudo_dir = '../../Pseudo',
!   forc_conv_thr = 1.0d-5
/
&SYSTEM
!   nosym=.true.
!   noinv=.true.
    ibrav = 1,
    A = 12.0
    nat = 8,
    ntyp = 2,
    ecutwfc = 50,
/
&ELECTRONS
    conv_thr = 1.0d-6,
/
&IONS
/
ATOMIC_SPECIES
C  12.011  C.upf
H   1.008  H.upf
ATOMIC_POSITIONS angstrom
C   0.000000   0.000000  -0.770000
C   0.000000   0.000000   0.770000
H   0.000000   1.020000  -1.160000
H   0.883000  -0.510000  -1.160000
H  -0.883000  -0.510000  -1.160000
H   0.000000   1.020000   1.160000
H   0.883000  -0.510000   1.160000
H  -0.883000  -0.510000   1.160000
K_POINTS {gamma}
