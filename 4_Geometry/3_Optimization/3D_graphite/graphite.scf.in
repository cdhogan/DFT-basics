&CONTROL
  calculation = 'scf'
  outdir = './tmp'
  prefix = 'graphite'
  pseudo_dir = '../../Pseudo/'
  tprnfor = .true.
  tstress = .true.
  verbosity = 'high'
/
&SYSTEM
  ecutwfc = 40
  ibrav = 4
  A = 2.46
  C = 6.77
  nat = 4
  nosym = .false.
  ntyp = 1
  occupations = 'fixed'
  degauss = 0.01
  vdw_corr='DFT-D3'
  dftd3_version=4
/
&ELECTRONS
  conv_thr =   1e-8
  electron_maxstep = 80
  mixing_beta =   0.6
/
ATOMIC_SPECIES
C      12.0107 C.upf
ATOMIC_POSITIONS crystal
C            0.0000000000       0.0000000000       0.2500000000
C            0.0000000000       0.0000000000       0.7500000000
C            0.3333333300       0.6666666700       0.2500000000
C            0.6666666700       0.3333333300       0.7500000000
K_POINTS automatic
9 9 4 0 0 0
