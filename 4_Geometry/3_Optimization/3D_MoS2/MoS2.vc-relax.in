&CONTROL
  calculation = 'vc-relax'
  outdir = './tmp'
  prefix = 'MoS2'
  pseudo_dir = './'
  tprnfor = .true.
  tstress = .true.
  verbosity = 'high'
/
&SYSTEM
  ibrav = 4
  A = 3.19
  C = 14.56
  ntyp = 2
  nat = 6
! nosym = .false.
  ecutwfc = 20
  occupations = 'fixed'
  degauss = 0.02
/
&ELECTRONS
  mixing_beta =   0.7
/
&IONS
  ion_dynamics = 'bfgs'
/
&CELL
  cell_dynamics = 'bfgs'
  press_conv_thr = 0.01
  cell_dofree = 'ibrav'
/
ATOMIC_SPECIES
Mo     95.96 Mo_ONCV_PBE-1.2.upf 
S      32.065 S_ONCV_PBE-1.2.upf 
ATOMIC_POSITIONS crystal
Mo           0.6666666700       0.3333333300       0.2500000000
Mo           0.3333333300       0.6666666700       0.7500000000
S            0.6666666700       0.3333333300       0.6330820000
S            0.3333333300       0.6666666700       0.3669180000
S            0.6666666700       0.3333333300       0.8669180000
