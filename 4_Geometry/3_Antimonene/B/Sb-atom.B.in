&CONTROL
    calculation       = 'scf'
    restart_mode      = 'from_scratch'
    prefix            = 'Sb-atom'
!   tstress           = .true.
!   tprnfor           = .true.
    pseudo_dir        = '/Users/cdhogan/Research/Codes/espresso/PSEUDO/DOJO-PBE-NC-SR-04-STD/'
    outdir            = './tmp'
    verbosity         = 'high'
    wf_collect        = .true.
/
&SYSTEM
                       ibrav = 1,
                           A = 10.00,
                         nat = 1,
                        ntyp = 1,
                     ecutwfc = 80 ,
!                    ecutrho = 800 ,
                        nbnd = 20,
                         nspin = 2
             tot_magnetization = 3
!                occupations = 'smearing' ,
!                    degauss = 0.01 ,
!                   smearing = 'm-v' ,
/
&ELECTRONS
                 mixing_beta = 0.7 ,
/
&IONS
/
&CELL
   press_conv_thr=0.001
   cell_dofree="2Dxy"
!  cell_dofree="ibrav+2Dxy"   ! QE 7.0
/
ATOMIC_SPECIES
   Sb   12.01100  Sb.upf
ATOMIC_POSITIONS crystal 
   Sb      0.000000000    0.000000000    0.000000000     0 0 0
K_POINTS {gamma}
