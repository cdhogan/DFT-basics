&CONTROL
    calculation       = 'vc-relax'
    restart_mode      = 'from_scratch'
    prefix            = 'Sb'
    tstress           = .true.
    tprnfor           = .true.
    pseudo_dir        = '/Users/cdhogan/Research/Codes/espresso/PSEUDO/SG15-1.2/'
    outdir            = './tmp'
    verbosity         = 'high'
    wf_collect        = .true.
/
&SYSTEM
                       ibrav = 4,
                           A = 4.12911,
                           C = 15,
                         nat = 2,
                        ntyp = 1,
                     ecutwfc = 60 ,
!                    ecutrho = 600 ,
                        nbnd = 20,
!                occupations = 'smearing' ,
!                    degauss = 0.01 ,
!                   smearing = 'm-v' ,
!vdw_corr='DFT-D3'
!dftd3_version=4
/
&ELECTRONS
                 mixing_beta = 0.7 ,
/
&IONS
/
&CELL
   press_conv_thr=0.001
   cell_dofree="2Dxy"
!  cell_dofree="ibrav+2Dxy"   ! QE 7.0
/
