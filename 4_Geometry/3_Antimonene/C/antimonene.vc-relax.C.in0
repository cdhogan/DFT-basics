&CONTROL
    calculation       = 'vc-relax'
    restart_mode      = 'from_scratch'
    prefix            = 'Sb'
    tstress           = .true.
    tprnfor           = .true.
    pseudo_dir        = '/Users/cdhogan/Research/Codes/espresso/PSEUDO/SSSP_1.3.0_PBE_eff/'
    outdir            = './tmp'
    verbosity         = 'high'
    wf_collect        = .true.
/
&SYSTEM
                       ibrav = 4,
                           A = 4.1224,
                           C = 15,
                         nat = 2,
                        ntyp = 1,
                     ecutwfc = 60 ,
                     ecutrho = 600 ,
                        nbnd = 20,
!                occupations = 'smearing' ,
!                    degauss = 0.01 ,
!                   smearing = 'm-v' ,
vdw_corr='DFT-D3'
dftd3_version=4
/
&ELECTRONS
                 mixing_beta = 0.7 ,
/
&IONS
/
&CELL
   press_conv_thr=0.001
   cell_dofree="2Dxy"
!  cell_dofree="ibrav+2Dxy"   ! QE 7.0
/
ATOMIC_SPECIES
   Sb   12.01100  sb_pbe_v1.4.uspp.F.UPF
ATOMIC_POSITIONS crystal 
   Sb      0.000000000    0.000000000    0.500000000     0 0 0
   Sb      0.333333333    0.666666667    0.609150000     1 1 1
K_POINTS automatic
  9 9 1	0 0 0
